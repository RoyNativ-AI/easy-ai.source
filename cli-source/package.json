{
  "name": "@easyai/cli",
  "version": "3.0.17",
  "description": "AI development tool with CLI and dashboard",
  "main": "dist/index.js",
  "bin": {
    "easyai": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cd ../web-ui && npm run build && cp -r dist ../cli-source/frontend-dist",
    "build:server": "tsc",
    "build:frontend": "cd ../web-ui && npm run build",
    "dev": "tsx watch src/cli.ts",
    "dev:frontend": "cd ../web-ui && npm run dev",
    "dev:backend": "node backend-server.js",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "ai",
    "cli",
    "development",
    "openai",
    "anthropic"
  ],
  "author": "EasyAI",
  "license": "MIT",
  "files": [
    "dist/",
    "frontend-dist/",
    "scripts/",
    "backend-server.js",
    "enhanced-server.js",
    "working-server.js",
    "src/",
    "tsconfig.json"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "axios": "^1.10.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "commander": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "inquirer": "^9.2.0",
    "openai": "^4.104.0",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/fs-extra": "^11.0.1",
    "@types/inquirer": "^9.0.3",
    "@types/node": "^20.0.0",
    "@types/node-forge": "^1.3.1",
    "tsx": "^3.12.0",
    "typescript": "^5.0.0"
  }
}
